# ─────────────────────────────────────────────────────────────
# EGL Nurture Signal — variables de entorno
# Copia este archivo a .env (local) o pega estos valores en
# Dokploy → tu proyecto → Environment.
# ─────────────────────────────────────────────────────────────

# --- Base de datos (Postgres en producción) ---
# En docker-compose estas tres crean el Postgres y la DATABASE_URL.
POSTGRES_USER=clasificador
POSTGRES_PASSWORD=cambia-esta-contrasena
POSTGRES_DB=clasificador
# La app la construye sola en compose; si corres sin Docker, ajústala:
# DATABASE_URL=postgresql://clasificador:cambia-esta-contrasena@db:5432/clasificador
# Para desarrollo local sin Postgres puedes usar SQLite:
# DATABASE_URL=sqlite:///./data/library.db

# --- DeepInfra / DeepSeek (selector y clasificador de vídeos) ---
DEEPINFRA_API_KEY=
# Slug EXACTO del modelo en deepinfra.com (verifícalo en la página del modelo).
# Por defecto DeepSeek V4 Flash (rápido, MoE 284B/13B activos, contexto 1M).
DEEPINFRA_MODEL=deepseek-ai/DeepSeek-V4-Flash
DEEPINFRA_BASE_URL=https://api.deepinfra.com/v1/openai

# --- URL pública (para construir los links trackeados) ---
# En Dokploy pon aquí el dominio que asignes a la app, p.ej. https://video.tudominio.com
BASE_URL=http://localhost:8000

# --- Seguridad ---
# Salt para hashear IPs en los eventos de click (ponla aleatoria).
SECRET_KEY=cambia-esta-clave-aleatoria
# Si lo defines, los endpoints /api/* mutantes exigen cabecera X-Admin-Token.
ADMIN_TOKEN=

# --- Idiomas preferidos para la transcripción (orden de prioridad) ---
TRANSCRIPT_LANGS=es,en

# --- Mensaje al lead ---
# Plantilla del mensaje. Placeholders: {setter} {link} {contact_name} {pain}
MESSAGE_TEMPLATE=Por lo que has hablado con "{setter}" y lo que has rellenado te paso este vídeo, que es muy importante que veas antes de la llamada, te va a ayudar a entender todo mejor: {link}
# Nombre del setter/closer por defecto (se puede sobreescribir por lead).
DEFAULT_SETTER=
